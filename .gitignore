# Editor / OS
.DS_Store

# Data directory: ignore the uncompressed records (data/fhir_processed/ etc.), but
# DO track data/fhir_processed.tar.gz so a clone already has the folder + archive,
# ready to extract in place with no manual mkdir.
data/*
!data/fhir_processed.tar.gz

# backend/data/ holds local-only files (e.g. Garmin OAuth tokens/cache); keep it out
# of git EXCEPT the real 30-day Garmin export, which we commit so a fresh clone runs
# on real wearable data out of the box (see app/wearable_source.py).
backend/data/*
!backend/data/garmin_samples.json

