# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored - never commit real secrets.

# ElevenLabs API key (Settings -> API Keys).
ELEVENLABS_API_KEY=

# OUTBOUND agent - conducts the daily scheduled check-in calls this backend dials.
# Its prompt MUST reference these dynamic variables so calls carry context:
#   {{patient_name}}  {{patient_age}}  {{recent_summary}}  {{questions}}
ELEVENLABS_AGENT_ID=

# INBOUND agent - answers patient call-backs. Configured in the ElevenLabs
# dashboard and linked to the inbound number. Its prompt MUST call the
# get_patient_context tool at the start of every call to load the caller's
# health record. See backend/integrations/INBOUND_AGENT_SETUP.md.
ELEVENLABS_INBOUND_AGENT_ID=

# SCREENING agent - runs the dementia voice-biomarker protocol (Mini-Cog recall,
# orientation, verbal fluency). Created via scripts/create_screening_agent.py,
# which prints the agent_id to paste here. Separate from the check-in agent.
ELEVENLABS_SCREENING_AGENT_ID=

# The ElevenLabs phone-number id (the registered Twilio number to dial FROM).
ELEVENLABS_AGENT_PHONE_NUMBER_ID=

# Twilio API key - optional; stored for completeness. The outbound-call endpoint
# dials via the Twilio number already linked to the ElevenLabs agent.
TWILIO_API_KEY=

# API key ElevenLabs sends as X-API-Key when calling the patient-context tool.
ELEVENLABS_TOOL_API_KEY=

# On-call nurse number (E.164) dialled when a patient is escalated to urgent,
# and when the patient does not answer their own emergency call.
NURSE_PHONE_NUMBER=

# Override the featured (real-watch) patient's phone (E.164) so the demo operator
# can be the patient and receive the live escalation call. Leave blank in prod.
GARMIN_PATIENT_PHONE=

# =============================================================================
# Privacy & data-protection controls (see PRIVACY.md). All OFF by default so the
# demo runs unchanged; switch on for the real, enforced behaviour.
# =============================================================================

# --- Encryption at rest (AES-256-GCM) ---
# Encrypt sensitive fields before they touch MongoDB. Needs `cryptography` and a
# 32-byte key (base64 or hex). The app fails closed at startup if on without them.
# Generate a key:
#   python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
CARELOOP_ENCRYPT_AT_REST=0
CARELOOP_DATA_KEY=

# --- Authentication + RBAC ---
# When on, protected endpoints require a bearer token / X-API-Key mapped to a role.
# Tokens: "token:role,token:role"  (roles: admin, clinician, coordinator).
CARELOOP_AUTH_ENABLED=0
CARELOOP_AUTH_TOKENS=

# --- Consent enforcement (PDPO DPP1/3, GDPR Art.9) ---
# When on, data-use endpoints (patient-context handed to the voice agent, data
# export) return 451 unless the patient has an active granted consent record. The
# spoken consent gate still runs on every call regardless of this flag.
CARELOOP_CONSENT_ENFORCEMENT=0

# --- Per-client integration keys (ElevenLabs server-tool callbacks) ---
# Optional. Give each caller its own rotatable key: "key:client,key:client".
# The single ELEVENLABS_TOOL_API_KEY above still works (folded in as "shared").
CARELOOP_TOOL_API_KEYS=

# --- Transport security ---
# Redirect HTTP->HTTPS + emit HSTS (TLS is terminated by your proxy/platform).
CARELOOP_FORCE_HTTPS=0
# Hardening response headers (harmless over HTTP; on by default).
CARELOOP_SECURITY_HEADERS=1

# --- Data residency (declared region: local | hk | eu) ---
CARELOOP_DATA_RESIDENCY=local

# --- Retention (days; 0 = keep forever). Purged daily + on demand. ---
CARELOOP_RETENTION_CHECKINS_DAYS=0
CARELOOP_RETENTION_CALLS_DAYS=0
CARELOOP_RETENTION_CONVERSATIONS_DAYS=0
CARELOOP_RETENTION_AUDIT_DAYS=0
CARELOOP_RETENTION_CONSENT_DAYS=0

# Privacy-policy version stamped onto consent records.
CARELOOP_PRIVACY_POLICY_VERSION=2026-06-07

# --- LLM provider for check-in question generation (data-residency control) ---
# "gemini" (default) sends patient summaries to Google's Gemini API (off-territory).
# "vllm" routes to a self-hosted / in-region OpenAI-compatible server instead, so
# special-category data never leaves your trust boundary. See llm/config.py and
# llm/serve_vllm.sh. Set the base URL to your in-region inference endpoint.
LLM_PROVIDER=gemini
# VLLM_BASE_URL=http://127.0.0.1:8001/v1
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
# API key for the Gemini API (required when LLM_PROVIDER=gemini) - generates the
# tailored check-in questions. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
