# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored — never commit real secrets.

# ElevenLabs API key (Settings -> API Keys).
ELEVENLABS_API_KEY=

# The ElevenLabs Conversational AI agent that conducts the call.
# Its prompt MUST reference these dynamic variables so calls carry context:
#   {{patient_name}}  {{patient_age}}  {{recent_summary}}  {{questions}}
ELEVENLABS_AGENT_ID=

# The ElevenLabs phone-number id (the registered Twilio number to dial FROM).
ELEVENLABS_AGENT_PHONE_NUMBER_ID=

# Twilio API key — optional; stored for completeness. The outbound-call endpoint
# dials via the Twilio number already linked to the ElevenLabs agent.
TWILIO_API_KEY=
